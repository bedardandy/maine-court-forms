# Never commit fill/audit run artifacts — these are large and reproducible.
evaluations/
intermediate/
reports/
**/*.filled.pdf
**/*.flat.pdf
**/*.audit.json
# ...but each form's schema.audit.json IS tracked: it's the build-time
# research half of schema.json (split out by tools/split_schema.py), not a
# run artifact.
!forms/*/schema.audit.json
*.pixmap.png

# Scratch vision-crop renders dumped at the repo root by the mapping/audit
# tools (e.g. _z_top.png, .bot.png, .improve_<form>_p<n>.png). Debris, never
# deliverables. No tracked PNGs exist, so these root-only globs are safe.
/_*.png
/.*.png
.improve_*.png

# Large raw catalog dump — kept on disk for the scaffold tool but excluded
# from git to keep the review bundle lean. Re-add when publishing if wanted.
catalog/inventory.json

# Blank source PDFs (~131 MB) are kept out of git until PDF-redistribution
# licensing is resolved (see LICENSE.md). They stay on disk for local
# fill/verify; each form's source_url in form.yaml drives the downloader
# fallback. Re-add this tree once licensing permits redistribution.
forms/**/*.pdf

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editor / OS
.DS_Store
*.swp
